{
  "name": "eventhub-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon src/server.js",
    "backup": "node ../backup_eventos.py || python ../backup_eventos.py",
    "verify": "node -e \"const db = require('./src/db-firestore'); db.verificarIntegridadeDados().then(console.log).catch(console.error);\"",
    "predeploy": "npm run verify && npm run backup",
    "deploy-safe": "npm run predeploy && echo 'Deploy seguro - dados protegidos'"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.13"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
